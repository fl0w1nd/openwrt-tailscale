#!/bin/sh

# LuCI RPC bridge for Tailscale management via rpcd exec plugin.

MANAGER_BIN="${MANAGER_BIN:-/usr/bin/tailscale-manager}"
TASK_DIR="${TASK_DIR:-/tmp/tailscale-rpc-tasks}"
LIB_DIR="${LIB_DIR:-/usr/lib/tailscale}"

# shellcheck source=/dev/null
. "$LIB_DIR/jsonutil.sh"

# Lightweight logging for sourced library modules.
# Libraries call log_info/log_error/log_warn; provide minimal implementations
# that write to a dedicated log file without pulling in the full entry script.
_RPC_LOG_FILE="/var/log/tailscale-manager.log"

log_info() {
    echo "[INFO] $1"
    logger -t "tailscale-manager" -p daemon.info "$1" 2>/dev/null || true
    printf '[%s] [INFO] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$_RPC_LOG_FILE" 2>/dev/null || true
}

log_error() {
    echo "[ERROR] $1" >&2
    logger -t "tailscale-manager" -p daemon.error "$1" 2>/dev/null || true
    printf '[%s] [ERROR] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$_RPC_LOG_FILE" 2>/dev/null || true
}

log_warn() {
    echo "[WARN] $1"
    logger -t "tailscale-manager" -p daemon.warn "$1" 2>/dev/null || true
    printf '[%s] [WARN] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" >> "$_RPC_LOG_FILE" 2>/dev/null || true
}

# Source a library module from $LIB_DIR if it exists.
_source_lib() {
    local lib="$1"
    if [ -f "$LIB_DIR/$lib" ]; then
        # shellcheck source=/dev/null
        . "$LIB_DIR/$lib"
        return 0
    fi
    return 1
}

# Extract a variable value from the manager entry script (without sourcing it).
# Usage: _read_manager_var VERSION
_read_manager_var() {
    local varname="$1"
    sed -n "s/^${varname}=\"\\([^\"]*\\)\"/\\1/p" "$MANAGER_BIN" | head -1
}

_get_repo_base_url() {
    local repo_base_url="${OPENWRT_TAILSCALE_REPO_BASE_URL:-}"
    [ -n "$repo_base_url" ] || repo_base_url=$(_read_manager_var DEFAULT_REPO_BASE_URL)
    printf '%s' "$repo_base_url"
}

read_input() {
    cat
}

json_get_param() {
    local input="$1"
    local key="$2"

    if command -v jsonfilter >/dev/null 2>&1; then
        printf '%s' "$input" | jsonfilter -e "$.${key}" 2>/dev/null || true
        return 0
    fi

    printf '%s' "$input" | sed -n "s/.*\"${key}\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" | sed -n '1p'
}

json_get_int_param() {
    local input="$1"
    local key="$2"
    local value=""

    if command -v jsonfilter >/dev/null 2>&1; then
        value=$(printf '%s' "$input" | jsonfilter -e "$.${key}" 2>/dev/null || true)
    else
        value=$(printf '%s' "$input" | sed -n "s/.*\"${key}\"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p" | sed -n '1p')
    fi

    case "$value" in
        ''|*[!0-9]*) return 1 ;;
        *) printf '%s' "$value" ;;
    esac
}

print_code_stdout() {
    local code="$1"
    local stdout="$2"
    printf '{"code":%s,"stdout":"%s"}' "$code" "$(json_escape "$stdout")"
}

task_path() {
    printf '%s/%s' "$TASK_DIR" "$1"
}

new_task_id() {
    local prefix="$1"
    local now rand

    now=$(date +%s 2>/dev/null || printf '0')
    rand=$$
    printf '%s-%s-%s' "$prefix" "$now" "$rand"
}

start_background_task() {
    local task_prefix="$1"
    shift

    local task base pid_file status_file log_file
    task=$(new_task_id "$task_prefix")
    base=$(task_path "$task")
    pid_file="${base}.pid"
    status_file="${base}.status"
    log_file="${base}.log"

    mkdir -p "$TASK_DIR"

    (
        "$@" >"$log_file" 2>&1
        printf '%s' "$?" >"$status_file"
        rm -f "$pid_file"
    ) &

    printf '%s' "$!" >"$pid_file"
    printf '{"code":0,"started":true,"task":"%s","stdout":"Task started"}' "$task"
}

print_task_status() {
    local task="$1"
    local base pid_file status_file log_file pid code stdout
    base=$(task_path "$task")
    pid_file="${base}.pid"
    status_file="${base}.status"
    log_file="${base}.log"

    if [ -f "$status_file" ]; then
        code=$(cat "$status_file" 2>/dev/null)
        stdout=$(cat "$log_file" 2>/dev/null)
        printf '{"done":true,"code":%s,"stdout":"%s"}' "${code:-1}" "$(json_escape "$stdout")"
        rm -f "$pid_file" "$status_file" "$log_file"
        return 0
    fi

    if [ -f "$pid_file" ]; then
        pid=$(cat "$pid_file" 2>/dev/null)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            printf '{"done":false}'
            return 0
        fi
        rm -f "$pid_file"
    fi

    printf '{"done":false}'
}

case "$1" in
list)
    cat <<'EOF'
{
    "get_status": {},
    "get_install_info": {},
    "get_latest_version": {},
    "get_latest_versions": {},
    "get_script_local_info": {},
    "get_script_update_info": {},
    "get_task_status": { "task": "" },
    "list_versions": { "limit": 0 },
    "list_official_releases": { "limit": 0 },
    "service_control": { "action": "" },
    "do_install": { "source": "", "storage": "", "auto_update": "" },
    "do_install_version": { "version": "", "source": "" },
    "do_update": {},
    "do_uninstall": {},
    "setup_firewall": {},
    "sync_scripts": {},
    "upgrade_scripts": {},
    "get_logs": {},
    "clear_log": { "log_type": "" }
}
EOF
    ;;
call)
    case "$2" in
        get_status)
            exec "$MANAGER_BIN" json-status
            ;;
        get_install_info)
            exec "$MANAGER_BIN" json-install-info
            ;;
        get_latest_version)
            exec "$MANAGER_BIN" json-latest-version
            ;;
        get_latest_versions)
            exec "$MANAGER_BIN" json-latest-versions
            ;;
        get_script_local_info)
            exec "$MANAGER_BIN" json-script-local-info
            ;;
        get_script_update_info)
            exec "$MANAGER_BIN" json-script-info
            ;;
        get_task_status)
            input=$(read_input)
            task=$(json_get_param "$input" task)
            case "$task" in
                install-*|install-version-*|update-*|upgrade-scripts-*) ;;
                *) printf '{"done":true,"code":-1,"stdout":"Unknown task"}' ; exit 0 ;;
            esac
            print_task_status "$task"
            ;;
        list_versions)
            input=$(read_input)
            limit=$(json_get_int_param "$input" limit 2>/dev/null || true)
            [ -n "$limit" ] || limit=20
            versions=$("$MANAGER_BIN" list-versions "$limit" 2>/dev/null || true)
            printf '{"versions":'
            printf '%s\n' "$versions" | json_array_from_lines
            printf '}'
            ;;
        list_official_releases)
            input=$(read_input)
            limit=$(json_get_int_param "$input" limit 2>/dev/null || true)
            [ -n "$limit" ] || limit=20
            versions=$("$MANAGER_BIN" list-official-versions "$limit" 2>/dev/null || true)
            printf '{"versions":'
            printf '%s\n' "$versions" | json_array_from_lines
            printf '}'
            ;;
        service_control)
            input=$(read_input)
            action=$(json_get_param "$input" action)
            case "$action" in
                start|stop|restart) ;;
                *) printf '{"code":-1,"stdout":"Invalid action"}' ; exit 0 ;;
            esac
            stdout=$(/etc/init.d/tailscale "$action" 2>&1)
            code=$?
            print_code_stdout "$code" "$stdout"
            ;;
        do_install)
            input=$(read_input)
            source=$(json_get_param "$input" source)
            storage=$(json_get_param "$input" storage)
            auto_update=$(json_get_param "$input" auto_update)
            set -- "$MANAGER_BIN" install-quiet
            [ -n "$source" ] && set -- "$@" --source "$source"
            [ -n "$storage" ] && set -- "$@" --storage "$storage"
            [ -n "$auto_update" ] && set -- "$@" --auto-update "$auto_update"
            start_background_task install "$@"
            ;;
        do_install_version)
            input=$(read_input)
            version=$(json_get_param "$input" version)
            source=$(json_get_param "$input" source)
            set -- "$MANAGER_BIN" install-version "$version"
            [ -n "$source" ] && set -- "$@" --source "$source"
            start_background_task install-version "$@"
            ;;
        do_update)
            start_background_task update "$MANAGER_BIN" update --auto
            ;;
        do_uninstall)
            stdout=$("$MANAGER_BIN" uninstall --yes 2>&1)
            code=$?
            print_code_stdout "$code" "$stdout"
            ;;
        setup_firewall)
            stdout=$(
                set -e
                _source_lib firewall.sh || { echo "Failed to load firewall.sh"; exit 1; }
                setup_tailscale_interface
                setup_tailscale_firewall_zone
                /etc/init.d/network reload >/dev/null 2>&1 || { echo "Failed to reload network"; exit 1; }
                /etc/init.d/firewall reload >/dev/null 2>&1 || { echo "Failed to reload firewall"; exit 1; }
                echo done
            ) 2>&1
            code=$?
            print_code_stdout "$code" "$stdout"
            ;;
        sync_scripts)
            stdout=$("$MANAGER_BIN" sync-scripts 2>&1)
            code=$?
            print_code_stdout "$code" "$stdout"
            ;;
        upgrade_scripts)
            start_background_task upgrade-scripts "$MANAGER_BIN" self-update --non-interactive
            ;;
        get_logs)
            manager_log=""
            tailscale_log=""
            [ -f /var/log/tailscale-manager.log ] && manager_log=$(tail -n 500 /var/log/tailscale-manager.log 2>/dev/null)
            [ -f /var/log/tailscale.log ] && tailscale_log=$(tail -n 500 /var/log/tailscale.log 2>/dev/null)
            printf '{"manager":"%s","tailscale":"%s"}' "$(json_escape "$manager_log")" "$(json_escape "$tailscale_log")"
            ;;
        clear_log)
            input=$(read_input)
            log_type=$(json_get_param "$input" log_type)
            case "$log_type" in
                manager) : > /var/log/tailscale-manager.log 2>/dev/null ;;
                tailscale) : > /var/log/tailscale.log 2>/dev/null ;;
                *) printf '{"code":-1}' ; exit 0 ;;
            esac
            printf '{"code":0}'
            ;;
        *)
            printf '{"error":"Method not found"}'
            ;;
    esac
    ;;
*)
    printf '{"error":"Unsupported action"}'
    exit 1
    ;;
esac
