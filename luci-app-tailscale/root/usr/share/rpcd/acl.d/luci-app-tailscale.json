{
	"luci-app-tailscale": {
		"description": "Grant access to Tailscale configuration",
		"read": {
			"uci": [
				"tailscale"
			],
			"ubus": {
				"luci.tailscale": [
					"get_status",
					"get_install_info",
					"get_latest_version",
					"list_versions"
				]
			}
		},
		"write": {
			"uci": [
				"tailscale"
			],
			"ubus": {
				"luci.tailscale": [
					"service_control",
					"do_install",
					"do_install_version",
					"do_update",
					"do_uninstall",
					"setup_firewall",
					"sync_scripts"
				]
			}
		}
	}
}
